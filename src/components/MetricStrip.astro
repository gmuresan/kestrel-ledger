---
// MetricStrip (Story 72.2, AC3) — the hero proof strip. Renders the pre-built state.json
// aggregate (G7); never a runtime fetch. Props/interface are unchanged — callers pass the
// same five fields. The redesign GROUPS the four figures into two clusters and leads with
// the safety pair (EXPERIENCE.md §Component Patterns; design-system contract):
//   "what it did"   — cycles supervised + self-custodied capital. Quieter weight, recessive ink.
//   "what it caught" — moves blocked + 0 drained. The DOMINANT cluster: larger figures, an
//                      accented frame, surfaced first so the safety story reads loudest.
//
// Non-negotiable rendering rules:
//  - Figures render their FINAL values immediately for everyone — no count-tick, no
//    animate-on-update (no JS at all; values are server-rendered text).
//  - The blocks stat is labeled "moves blocked" — the policy is the fact, and the editorial
//    adjective the spec bans (applied to "moves") is never used.
//  - "moves blocked" is the star — it carries the --intercept (red) accent. "0 drained"
//    ALWAYS renders, but NEUTRAL in var(--ink-primary), scoped "to date" — never green
//    (var(--proceed)), never a guarantee of future safety.
//  - selfCustodiedCapital renders its formatted USD string, or "$—" (em-dash) when null —
//    an honest unavailable, never a fabricated $0.
import type { SelfCustodiedCapital } from '../lib/state-types';

interface Props {
  cyclesSupervised: number;
  selfCustodiedCapital: SelfCustodiedCapital | null;
  movesBlocked: number;
  drained: 0;
  generatedAt: string;
}
const { cyclesSupervised, selfCustodiedCapital, movesBlocked, drained, generatedAt } =
  Astro.props;

const capital = selfCustodiedCapital !== null ? selfCustodiedCapital.formatted : '$—';
// Format in UTC so the freshness date is deterministic across build environments (it must
// match the UTC date in generatedAt regardless of the runner's local timezone).
const asOf = new Date(generatedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<div class="metric-strip" role="group" aria-label="The record, current as of last publish">
  {/* WHAT IT CAUGHT — the dominant cluster, surfaced first; the safety story leads. */}
  <section class="cluster cluster--caught" aria-label="What the safety layer caught">
    <span class="cluster-label">what it caught</span>
    <div class="cluster-figures">
      <div class="metric-strip-stat stat--star">
        <span class="value mono">{movesBlocked}</span>
        <span class="label">moves blocked</span>
      </div>
      <div class="metric-strip-stat">
        <span class="value mono drained">{drained}</span>
        <span class="label">drained <span class="scope">to date</span></span>
      </div>
    </div>
  </section>

  {/* WHAT IT DID — the quieter cluster; capital + cadence demoted to recessive weight. */}
  <section class="cluster cluster--did" aria-label="What the agent did">
    <span class="cluster-label">what it did</span>
    <div class="cluster-figures">
      <div class="metric-strip-stat">
        <span class="value mono">{cyclesSupervised}</span>
        <span class="label">cycles supervised</span>
      </div>
      <div class="metric-strip-stat">
        <span class="value mono">{capital}</span>
        <span class="label">self-custodied</span>
      </div>
    </div>
  </section>

  <p class="freshness mono">as of {asOf}</p>
</div>

<style>
  .metric-strip {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    gap: var(--gutter);
    background: var(--surface-raised);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: var(--stack);
    margin: var(--section-gap-mobile) 0 0;
  }

  /* ── Clusters ──────────────────────────────────────────────────────────────
   * Two labeled groups. "What it caught" is the elevation-2 accented well so the
   * safety pair reads as the dominant frame; "what it did" sits flat/recessive.
   */
  .cluster {
    display: flex;
    flex-direction: column;
    gap: var(--stack);
    border-radius: var(--radius-md);
    padding: var(--stack);
  }

  /* The safety pair: lifted onto the overlay surface inside an intercept-edged
   * frame so the eye lands here first. The frame is accented (red edge), but the
   * "0 drained" figure inside it stays NEUTRAL ink — never a victory-lap color. */
  .cluster--caught {
    background: var(--surface-overlay);
    border: 1px solid var(--intercept-edge);
  }

  /* The activity pair: no frame, recessive — demoted against the safety cluster. */
  .cluster--did {
    background: transparent;
    border: 1px solid transparent;
  }

  .cluster-label {
    font-family: var(--font-body);
    font-size: var(--type-eyebrow-size);
    font-weight: var(--label-caps-weight);
    letter-spacing: var(--type-eyebrow-ls);
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .cluster--caught .cluster-label {
    color: var(--intercept);
  }

  .cluster-figures {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--gutter);
  }

  .metric-strip-stat {
    display: flex;
    flex-direction: column;
    gap: var(--stack-tight);
  }

  .value {
    font-family: var(--font-mono);
    font-size: var(--mono-data-lg-size);
    font-weight: var(--mono-data-lg-weight);
    color: var(--ink-primary);
    line-height: 1.05;
  }

  /* "What it did" is the quieter cluster — its figures recede in ink + scale. */
  .cluster--did .value {
    font-size: var(--display-lg-size, 36px);
    color: var(--ink-secondary);
  }

  /* The safety pair dominates: larger figures than the activity cluster. */
  .cluster--caught .value {
    font-size: var(--display-xl-size);
    line-height: var(--display-xl-lh);
  }

  /* "moves blocked" is the star figure — it carries the intercept accent. */
  .stat--star .value {
    color: var(--intercept);
  }

  /* 0 drained is an observed count, never a victory lap — neutral ink, never green. */
  .value.drained {
    color: var(--ink-primary);
  }

  .label {
    font-family: var(--font-body);
    font-size: var(--label-caps-size);
    font-weight: var(--label-caps-weight);
    letter-spacing: var(--label-caps-ls);
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .scope {
    color: var(--ink-secondary);
  }

  .freshness {
    grid-column: 1 / -1;
    font-family: var(--font-mono);
    font-size: var(--mono-sm-size);
    color: var(--ink-muted);
    margin: 0;
    text-align: right;
  }

  /* ── Responsive (Story 72.3, AC5) — never overflow horizontally on mobile. ── */
  /* Tablet/mobile: the two clusters stack; the safety cluster stays first (DOM order). */
  @media (max-width: 768px) {
    .metric-strip {
      grid-template-columns: 1fr;
    }
    .freshness {
      text-align: left;
    }
  }

  /* Mobile: figures within a cluster stack so the mono-data figures stay readable. */
  @media (max-width: 480px) {
    .cluster-figures {
      grid-template-columns: 1fr;
    }
    /* Keep the dominant safety figures from overflowing on the narrowest screens. */
    .cluster--caught .value {
      font-size: var(--mono-data-lg-size);
    }
  }
</style>
