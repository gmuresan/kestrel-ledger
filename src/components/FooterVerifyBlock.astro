---
// FooterVerifyBlock (Story 72.1, AC3) — the trust anchor. Shows the public wallet
// address (full, copyable, mono) with an explorer link, plus the honest
// "what this is / what this isn't" disclosure.
//
// Microcopy rule (DESIGN.md do/don't): say "self-custodied by the operator" —
// never "trustless" or "non-custodial" for the overseer.
//
// Defaults come from src/lib/site.ts so the REAL wallet + explorer link render on
// EVERY route — including /about, /waitlist, /ledger — instead of the placeholder.
// A page may still override by passing explicit props (e.g. a per-entry wallet).
import { WALLET, WALLET_EXPLORER_URL, EXPLORER_NAME } from '../lib/site';

interface Props {
  wallet?: string;
  explorerUrl?: string;
  explorerName?: string;
}
const {
  wallet = WALLET,
  explorerUrl = WALLET_EXPLORER_URL,
  explorerName = EXPLORER_NAME,
} = Astro.props;
const linkLabel = explorerName ? `↗ ${explorerName}` : '↗ view on the block explorer';
---

<footer class="footer-verify">
  <div class="footer-inner">
    <p class="label">VERIFY ON CHAIN</p>
    <p class="wallet">
      <span class="address mono">{wallet}</span>
      {
        explorerUrl && (
          <a class="explorer" href={explorerUrl} rel="noopener noreferrer" target="_blank">
            {linkLabel}
          </a>
        )
      }
    </p>
    <p class="verify-link">
      <a class="explorer" href="/verify/" rel="noopener noreferrer">↗ Verify receipts</a>
    </p>
    <p class="disclosure">
      This is a self-custodied record: the operator holds the keys and publishes what the
      supervised agent did, with on-chain receipts you can check yourself. It is not a promise
      of any outcome.
    </p>
  </div>
</footer>

<style>
  /* Trust anchor: the recessed verify well (surface-sunken) capped by a strong
     top divider so it reads as a distinct foot of the page. Inner content is held
     to --content-max so it lines up with the nav + main column above it. */
  .footer-verify {
    background: var(--surface-sunken);
    border-top: 1px solid var(--border-strong);
    margin-top: var(--section-gap-mobile);
    padding: var(--gutter) var(--margin-mobile);
  }

  .footer-inner {
    max-width: var(--content-max);
    margin: 0 auto;
  }

  .label {
    font-family: var(--font-body);
    font-size: var(--type-eyebrow-size);
    font-weight: var(--label-caps-weight);
    letter-spacing: var(--type-eyebrow-ls);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0 0 var(--stack-tight);
  }

  .wallet {
    margin: 0 0 var(--stack);
  }

  .address {
    font-family: var(--font-mono);
    font-size: var(--mono-data-size);
    color: var(--ink-secondary);
    user-select: all;
  }

  .explorer {
    color: var(--info);
    margin-left: var(--stack);
  }

  .disclosure {
    font-family: var(--font-body);
    font-size: var(--body-sm-size);
    color: var(--ink-muted);
    max-width: var(--reading-measure);
    margin: 0;
  }
</style>
