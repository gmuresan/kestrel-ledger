---
// WaitlistSection (Story 75.8, AC1–AC4) — a Kit (kit.com) email capture.
// Managed double-opt-in, unsubscribe, CAN-SPAM/GDPR all live in Kit (locked decision LD5), so
// this repo ships zero server-side code. The form POSTs directly to Kit's form endpoint, so it
// works on the static Cloudflare deploy with no Cloudflare Function (AC1). No third-party script
// is loaded: the native POST IS the submission path (the JS-off fallback Kit forms rely on), so
// the whole site stays script-clean (AC3).
//
// G14 — the CTA is bound and private: it invites interest WHEN THE PRODUCT IS READY, never
// promises a return, a guarantee, or that the product exists today. A clear privacy line names
// Kit's managed unsubscribe. No dark patterns, no pre-checked consent.
//
// G2 — every string below (markup AND these comments) must survive the lintHomepageCopy
// banned-phrase gate; see BANNED_TERMS in scripts/lint-homepage-copy.ts for the denylist.
//
// KIT_FORM_ID is public (it appears in any Kit embed snippet), so it lives in the form `action=`
// URL as a literal. Replace it if the Kit form is recreated.
const KIT_FORM_ID = '9596459';
const EMBED_ACTION = `https://app.kit.com/forms/${KIT_FORM_ID}/subscriptions`;
---

<section class="waitlist" id="waitlist" aria-label="Waitlist">
  <h2 class="section-title">Be first to try it</h2>
  <p class="body">
    This is a public record today — not a product you can buy. Leave your email and we'll reach
    out when access opens.
  </p>

  <form class="embeddable-kit-form" action={EMBED_ACTION} method="post" target="popupwindow">
    <label class="field-label" for="kit-email">Email address</label>
    <div class="field-row">
      <input
        id="kit-email"
        class="email-input"
        type="email"
        name="email_address"
        placeholder="you@example.com"
        autocomplete="email"
        required
      />
      <button class="submit" type="submit">Notify me</button>
    </div>
  </form>

  <p class="privacy">
    No spam. Waitlist updates only. Unsubscribe at any time — the list is managed by Kit.
  </p>
</section>

<style>
  .waitlist {
    margin: var(--section-gap-mobile) 0 0;
    max-width: var(--reading-measure);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--headline-size);
    font-weight: 500;
    color: var(--ink-primary);
    margin: 0 0 var(--stack);
  }

  .body {
    font-family: var(--font-body);
    font-size: var(--body-size);
    line-height: var(--body-lh);
    color: var(--ink-secondary);
    margin: 0 0 var(--stack);
  }

  .field-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--label-caps-size);
    font-weight: var(--label-caps-weight);
    letter-spacing: var(--label-caps-ls);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0 0 var(--stack-tight);
  }

  .field-row {
    display: flex;
    gap: var(--stack);
    align-items: stretch;
    flex-wrap: wrap;
  }

  .email-input {
    flex: 1 1 18rem;
    min-width: 0;
    border-radius: var(--radius);
    border: 1px solid var(--hairline-strong);
    background: transparent;
    color: var(--ink-primary);
    font-family: var(--font-body);
    font-size: var(--body-size);
    padding: 12px 14px;
  }

  .email-input::placeholder {
    color: var(--ink-muted);
  }

  .submit {
    border-radius: var(--radius);
    border: none;
    background: var(--brand);
    color: var(--ink-on-accent);
    font-family: var(--font-body);
    font-size: var(--label-caps-size);
    font-weight: var(--label-caps-weight);
    letter-spacing: var(--label-caps-ls);
    text-transform: uppercase;
    padding: 12px 20px;
    cursor: pointer;
  }

  .privacy {
    font-family: var(--font-body);
    font-size: var(--body-sm-size);
    line-height: var(--body-lh);
    color: var(--ink-muted);
    margin: var(--stack) 0 0;
  }
</style>
