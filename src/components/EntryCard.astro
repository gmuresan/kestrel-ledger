---
// EntryCard (Story 72.1, AC3) — archive/timeline list item. surface-raised card
// with a 3px left accent bar tinted by stream color (the at-a-glance stream
// signal). The record is textual — no images.
import StreamBadge from './StreamBadge.astro';

interface Props {
  title: string;
  date: string;
  stream: 'agent-ledger' | 'build-log';
  slug: string;
  // Story 75.5 (AC3): optional per-agent attribution. When present and non-empty, a small
  // agent chip renders beside the stream badge so readers see which agent authored the entry
  // at a glance. Absent (pre-75.5 entries) → no chip, never an error.
  agentSlug?: string;
}
const { title, date, stream, slug, agentSlug } = Astro.props;
const accent = stream === 'agent-ledger' ? 'var(--stream-agent)' : 'var(--stream-build)';
const displayDate = date.includes('T') ? date.slice(0, date.indexOf('T')) : date;
---

<a class="card-elevated entry-card" href={`/ledger/${slug}/`} style={`--accent: ${accent}`}>
  <div class="meta">
    <StreamBadge stream={stream} />
    <span class="date">{displayDate}</span>
    {agentSlug && <span class="agent-chip">{agentSlug}</span>}
  </div>
  <h2 class="title">{title}</h2>
</a>

<style>
  /* Surface, border, shadow + hover lift come from the global .card-elevated.
     Scoped CSS only adds the per-stream left accent bar, layout, and the card-title
     hierarchy (--type-card-*). */
  .entry-card {
    display: block;
    position: relative;
    /* The stream-tinted accent edge overrides .card-elevated's left border. */
    border-left: 3px solid var(--accent);
    padding: var(--stack);
    margin: var(--stack) 0;
    text-decoration: none;
  }

  /* Keep the stream accent on the left even when .card-elevated:hover restyles the border. */
  .entry-card:hover {
    border-left-color: var(--accent);
    text-decoration: none;
  }

  .meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--stack-tight) var(--gutter);
    margin-bottom: var(--stack-tight);
  }

  .date {
    font-family: var(--font-mono);
    font-size: var(--mono-sm-size);
    color: var(--ink-muted);
  }

  /* Per-agent attribution chip (75.5, AC3) — neutral pill, mono, no decoration.
     Reuses the global .chip token treatment via local scoped styling to stay light. */
  .agent-chip {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--mono-sm-size);
    color: var(--ink-secondary);
    padding: 2px 8px;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-full);
    background: var(--surface-overlay);
  }

  /* Card title — the named 20px Newsreader card step, distinct from hero/section heads. */
  .title {
    font-family: var(--font-display);
    font-size: var(--type-card-size);
    line-height: var(--type-card-lh);
    font-weight: 500;
    color: var(--ink-primary);
    margin: 0;
  }
</style>
