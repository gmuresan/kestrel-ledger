---
// Marketing landing (Story 72.2) — the full 5-section landing IA from EXPERIENCE.md, replacing
// the 72.1 holding stub. It is both a pitch and a proof: static Gm-owned copy persuades, while
// the live-state widgets beneath it (from src/data/state.json, the pre-built aggregate) make
// every figure checkable.
//
// G7 build-time isolation: the widget data is a STATIC import of state.json resolved at build
// time — this page never makes a runtime HTTP call. The generator (scripts/generate-homepage-
// state.ts) refreshes state.json locally before each publish.
//
// The hero headline + subhead are VERBATIM from the spec and must not be paraphrased (AC1).
// The §2 step copy and §5 disclosure are Gm-owned static text (no banned terms — G2).
import BaseLayout from '../layouts/BaseLayout.astro';
import MetricStrip from '../components/MetricStrip.astro';
import CycleTape from '../components/CycleTape.astro';
import HowItWorksSection from '../components/HowItWorksSection.astro';
import SafetyLayerSection from '../components/SafetyLayerSection.astro';
import LatestEntriesSection from '../components/LatestEntriesSection.astro';
import FleetRosterSection from '../components/FleetRosterSection.astro';
import ScreenshotGallery from '../components/ScreenshotGallery.astro';
import WaitlistSection from '../components/WaitlistSection.astro';
import state from '../data/state.json';
import screenshotsRaw from '../data/screenshots.json';
import type { HomepageState } from '../lib/state-types';
import type { ScreenshotManifestEntry } from '../lib/screenshot-types';

// state.json is the build-shape contract #3 aggregate; type it for the widgets (G1/G7).
const s = state as HomepageState;

// Story 75.5 (AC1/AC4): when the aggregate carries a fleet roll-up AND at least one agent,
// the homepage leads with the fleet — the MetricStrip shows the fleet figures and the
// FleetRosterSection renders below it. Absent fleet/perAgent → the existing single-agent
// layout is unchanged (AC4 honest fleet-of-one). `metricsToShow` is the fleet roll-up when
// present, else the top-level single-agent figures; both share the MetricStrip field shape.
const hasFleet = s.fleet != null && s.perAgent != null && Object.keys(s.perAgent).length > 0;
const metricsToShow = hasFleet ? s.fleet! : s;

// The agent's public wallet, surfaced in the footer verify block (already public on-chain).
const WALLET = '0x326e18Ade6Edc700F765F0906B5C5f05FF51F753';
const EXPLORER_URL = `https://basescan.org/address/${WALLET}`;
const EXPLORER_NAME = 'view on basescan';

// Story 75.7 (AC1) — surface the current dashboard screenshot beneath the CTA (G10 — proof under
// the pitch). Prefer the 'home' view; fall back to the first manifest entry. Empty manifest →
// heroShots is [] → ScreenshotGallery renders nothing (graceful degradation, AC1/AC2).
const screenshots = screenshotsRaw as ScreenshotManifestEntry[];
const homeShot = screenshots.find((shot) => shot.viewId === 'home') ?? screenshots[0] ?? null;
const heroShots = homeShot ? [homeShot] : [];
---

<BaseLayout
  title="Kestrel Ledger"
  wallet={WALLET}
  explorerUrl={EXPLORER_URL}
  explorerName={EXPLORER_NAME}
>
  {/* ── §1 Hero ───────────────────────────────────────────────────────── */}
  <section class="hero">
    <p class="eyebrow">KESTREL LEDGER</p>
    <p class="tagline">Kestrel — the oversight agent that watches your onchain AI before it moves your money.</p>
    <h1>Know exactly what an AI does with real money — before you trust one with yours.</h1>
    {
      hasFleet ? (
        <p class="lede">
          An overseer supervises a fleet of autonomous agents running live capital on-chain under
          a safety layer. Every action, and every move the rail blocks, is on the public record.
        </p>
      ) : (
        <p class="lede">
          An autonomous agent runs live capital on-chain under a supervised safety layer. Every
          action it takes, and every move the rail blocks, is on the public record.
        </p>
      )
    }

    <MetricStrip
      cyclesSupervised={metricsToShow.cyclesSupervised}
      selfCustodiedCapital={metricsToShow.selfCustodiedCapital}
      movesBlocked={metricsToShow.movesBlocked}
      drained={metricsToShow.drained}
      generatedAt={s.generatedAt}
    />

    {/* The cycle tape reads from the SAME fleet roll-up the MetricStrip uses, so the
        glanceable mark count and the "cycles supervised" / "moves blocked" figures agree. */}
    <CycleTape
      total={metricsToShow.cyclesSupervised}
      intercepted={metricsToShow.movesBlocked}
    />

    <p class="cta">
      <a class="cta-button primary" href="/ledger">READ THE LEDGER</a>
      <a class="cta-button ghost" href="/feed.xml">RSS</a>
    </p>

    {/* §1.5 Proof under the pitch (Story 75.7, G10) — the product the pitch describes. */}
    <ScreenshotGallery shots={heroShots} />
  </section>

  {/* ── §1.6 The fleet ────────────────────────────────────────────────── */}
  {
    hasFleet && (
      <section class="section-band section-band--alt">
        <FleetRosterSection perAgent={s.perAgent!} />
      </section>
    )
  }

  {/* ── §2 How it works ───────────────────────────────────────────────── */}
  <section class="section-band">
    <HowItWorksSection />
  </section>

  {/* ── §3 The safety layer, on the record ────────────────────────────── */}
  <section class="section-band section-band--alt">
    <SafetyLayerSection interceptions={s.latestInterceptions} generatedAt={s.generatedAt} />
  </section>

  {/* ── §4 Latest from both streams ───────────────────────────────────── */}
  <section class="section-band">
    <LatestEntriesSection latestByStream={s.latestByStream} generatedAt={s.generatedAt} />
  </section>

  {/* ── §5 What this is / isn't (the two required disclaimers) ─────────── */}
  <section class="section-band section-band--alt disclosure" aria-label="What this is and isn't">
    <p class="eyebrow">WHAT THIS IS</p>
    <h2 class="section-heading">What this is — and what it isn’t</h2>
    <p class="body">
      What this is: a public record of one agent’s decisions and what the safety layer did, with
      on-chain receipts you can check yourself. What this isn’t: investment advice, a product you
      can buy, or a promise of returns.
    </p>
    <p class="body">
      The record shows every interception the safety layer made — not that it catches everything.
      The zero-drained count is historical to the date shown; it is not a guarantee of future
      outcomes.
    </p>
  </section>

  {/* ── §6 Waitlist ──────────────────────────────────────────────────── */}
  <section class="section-band">
    <WaitlistSection />
  </section>
</BaseLayout>

<style>
  /* Symmetric vertical rhythm: the hero needs a bottom gap too, so its last child
     (the screenshot exhibit / CTA) isn't flush against the next full-bleed band. */
  .hero {
    max-width: var(--entry-max);
    margin: var(--section-gap-mobile) auto;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: var(--label-caps-size);
    font-weight: var(--label-caps-weight);
    letter-spacing: var(--label-caps-ls);
    color: var(--brand);
    margin: 0 0 var(--stack);
  }

  .tagline {
    font-size: var(--text-sm, 0.9rem);
    color: var(--ink-muted);
    margin-block: 0.5rem 1rem;
    max-width: 56ch;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: var(--display-xl-size);
    font-weight: var(--display-xl-weight);
    line-height: var(--display-xl-lh);
    letter-spacing: var(--display-xl-ls);
    margin: 0;
  }

  .lede {
    font-family: var(--font-body);
    font-size: var(--body-lg-size);
    line-height: var(--body-lg-lh);
    color: var(--ink-secondary);
    max-width: var(--reading-measure);
    margin: var(--stack) 0 0;
  }

  .cta {
    margin-top: var(--section-gap-mobile);
    display: flex;
    gap: var(--stack);
    align-items: center;
  }

  .cta-button {
    display: inline-block;
    border-radius: var(--radius);
    padding: 12px 20px;
    font-family: var(--font-body);
    font-size: var(--label-caps-size);
    font-weight: var(--label-caps-weight);
    letter-spacing: var(--label-caps-ls);
    text-decoration: none;
  }

  .cta-button.primary {
    background: var(--brand);
    color: var(--ink-on-accent);
  }

  /* Quiet/ghost secondary CTA — recedes next to the amber primary. */
  .cta-button.ghost {
    background: transparent;
    color: var(--ink-muted);
    border: 1px solid var(--border-subtle);
  }

  .cta-button.ghost:hover {
    color: var(--ink-secondary);
    border-color: var(--border-strong);
  }

  .cta-button:hover {
    text-decoration: none;
  }

  /* The cycle tape sits just under the hero metric strip as glanceable proof. */
  .hero :global(.cycle-tape-wrap) {
    margin-top: var(--stack);
  }

  /* ── Section rhythm: the bands supply vertical gap + dividers, so the wrapped
     child sections must not re-add their own leading section-gap margin (it would
     double the spacing). Zero the top margin of each band's first section child. ── */
  .section-band > :global(section) {
    margin-top: 0;
  }

  .disclosure {
    max-width: var(--reading-measure);
  }

  .disclosure .section-heading {
    margin-bottom: var(--stack);
  }

  .disclosure .body {
    font-family: var(--font-body);
    font-size: var(--body-sm-size);
    line-height: var(--body-lh);
    color: var(--ink-muted);
    margin: 0 0 var(--stack);
  }

  /* ── Responsive (Story 72.3, AC5) — the 56px display headline must not overflow. ── */
  @media (max-width: 768px) {
    .hero h1 {
      font-size: clamp(2rem, 7vw, var(--display-xl-size));
    }
  }

  @media (max-width: 480px) {
    .hero h1 {
      font-size: clamp(1.6rem, 8vw, 2.25rem);
    }
    .cta {
      flex-wrap: wrap;
    }
  }
</style>
