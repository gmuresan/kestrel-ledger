---
// Ledger archive (Story 72.1, AC2) — /ledger/ lists every entry NEWEST-FIRST as
// a styled list of elevated cards (not a flat markdown table). Sorted by
// frontmatter `date` descending.
//
// Redesign (Epic): each row is a `.card-elevated` row carrying a one-line dek
// (first prose sentence — real entry text, never invented) and a count chip whose
// number is derived HONESTLY from the entry's own fact-panel signals via the same
// pure `parseEntrySignals` parser the detail page uses (G1 provenance). When no
// clean count is derivable (a prose-only Build Log entry has no fact panel → zero
// signals) the row shows the stream badge + date + dek only — never a fabricated
// number. The FILTER / AGENT chip controls are polished with contract tokens.
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StreamBadge from '../../components/StreamBadge.astro';
import { splitEntry } from '../../lib/split-entry';
import { parseEntrySignals } from '../../lib/parse-entry-signals';

const entries = await getCollection('ledger');
// Newest-first by date. Ties fall back to the slug (filename) descending, which
// preserves the 71 same-day seq ordering (seq 02 above seq 01).
const sorted = entries.sort((a, b) => {
  const byDate = b.data.date.localeCompare(a.data.date);
  return byDate !== 0 ? byDate : b.slug.localeCompare(a.slug);
});
const wallet = sorted[0]?.data.wallet;

// Story 75.5 (AC3): per-agent filter options — one button per distinct agentSlug observed in
// the collection, plus "All". Entries without an agentSlug (pre-75.5) are grouped under "All"
// and never hidden; they carry data-agent-entry="unknown".
const agentSlugs = [...new Set(sorted.map((e) => e.data.agentSlug).filter(Boolean))] as string[];

// Build-time row enrichment — all derived from the entry's OWN committed content.
// dek  : the first sentence of the editorial prose (real text, trimmed to one line).
// blocked / flagged : interception counts traced to the deterministic fact panel via
//   parseEntrySignals (the SAME parser the detail page renders callouts from). We split
//   the signals by verdict meaning per the color-meaning contract:
//     - blocked (--intercept, the star): denials + critic ERROR flags — moves the rail stopped.
//     - flagged (--caution, a warning): oscillation / non-error critic / projected-vs-realized miss.
//   A prose-only entry (no fact panel) yields zero of both → no count chip is shown.
const FIRST_SENTENCE = /^[\s\S]*?[.!?](?=\s|$)/;
function firstSentence(prose: string): string {
  const flat = prose.replace(/\s+/g, ' ').trim();
  const m = FIRST_SENTENCE.exec(flat);
  return (m ? m[0] : flat).trim();
}

const rows = sorted.map((entry) => {
  const { prose, fact } = splitEntry(entry.body);
  const signals = parseEntrySignals(fact);
  let blocked = 0;
  let flagged = 0;
  for (const s of signals) {
    if (s.kind === 'denial' || (s.kind === 'critic' && s.severity.toLowerCase() === 'error')) {
      blocked += 1;
    } else {
      flagged += 1;
    }
  }
  return { entry, dek: firstSentence(prose), blocked, flagged };
});
---

<BaseLayout title="Ledger — Kestrel" wallet={wallet}>
  <header class="archive-head">
    <p class="eyebrow">THE RECORD</p>
    <h1>Ledger</h1>
    <p class="lede">
      Every supervised cycle, on the record — what the agent proposed, what the safety layer
      caught, and the on-chain receipts you can check yourself.
    </p>
  </header>

  {
    rows.length === 0 ? (
      <p class="empty">No entries yet.</p>
    ) : (
      <>
        {/* Stream filter (Story 72.8, AC1) — progressive enhancement. The control is
            hidden by default and revealed by the inline script; JS-off readers get the
            full interleaved list with no broken UI. `?stream=` is client-side only —
            no server-side filtering, no dynamic [stream].astro route. */}
        <div data-stream-filter class="chip-filter js-only" hidden>
          <span class="chip-filter__label">Filter</span>
          <button type="button" data-stream-value="all" class="filter-chip active">All</button>
          <button type="button" data-stream-value="agent-ledger" class="filter-chip">Agent Ledger</button>
          <button type="button" data-stream-value="build-log" class="filter-chip">Build Log</button>
        </div>

        {/* Per-agent filter (Story 75.5, AC3) — progressive enhancement, mirrors the stream
            filter. Hidden until the inline script reveals it; JS-off readers get the full list.
            Only rendered when at least one entry carries an agentSlug. */}
        {agentSlugs.length > 0 && (
          <div data-agent-filter class="chip-filter js-only" hidden>
            <span class="chip-filter__label">Agent</span>
            <button type="button" data-agent-value="all" class="filter-chip active">All</button>
            {agentSlugs.map((slug) => (
              <button type="button" data-agent-value={slug} class="filter-chip">
                {slug}
              </button>
            ))}
          </div>
        )}

        <ol class="entry-list">
          {rows.map(({ entry, dek, blocked, flagged }) => {
            const accent =
              entry.data.stream === 'agent-ledger' ? 'var(--stream-agent)' : 'var(--stream-build)';
            const displayDate = entry.data.date.includes('T')
              ? entry.data.date.slice(0, entry.data.date.indexOf('T'))
              : entry.data.date;
            return (
              <li
                data-stream-entry={entry.data.stream}
                data-agent-entry={entry.data.agentSlug ?? 'unknown'}
              >
                <a
                  class="entry-row card-elevated"
                  href={`/ledger/${entry.slug}/`}
                  style={`--accent: ${accent}`}
                >
                  <div class="entry-row__meta">
                    <StreamBadge stream={entry.data.stream} />
                    <span class="entry-row__date">{displayDate}</span>
                    {entry.data.agentSlug && (
                      <span class="agent-chip">{entry.data.agentSlug}</span>
                    )}
                  </div>
                  <h2 class="entry-row__title">{entry.data.title}</h2>
                  {dek && <p class="entry-row__dek">{dek}</p>}
                  {(blocked > 0 || flagged > 0) && (
                    <div class="entry-row__signals">
                      {blocked > 0 && (
                        <span class="chip chip--intercept">
                          {blocked} blocked
                        </span>
                      )}
                      {flagged > 0 && (
                        <span class="chip chip--caution">
                          {flagged} flagged
                        </span>
                      )}
                    </div>
                  )}
                </a>
              </li>
            );
          })}
        </ol>
      </>
    )
  }

  <script is:inline>
    (function () {
      const streamFilter = document.querySelector('[data-stream-filter]');
      const agentFilter = document.querySelector('[data-agent-filter]');
      if (!streamFilter && !agentFilter) return;
      // Progressive-enhancement reveal (only the controls that exist).
      if (streamFilter) streamFilter.removeAttribute('hidden');
      if (agentFilter) agentFilter.removeAttribute('hidden');

      const params = new URLSearchParams(location.search);
      let stream = params.get('stream') || 'all';
      let agent = params.get('agent') || 'all';

      // Both filters compose: an entry shows only when it matches the active stream AND the
      // active agent. Each filter is independent — setting one never clears the other.
      function render() {
        document.querySelectorAll('[data-stream-entry]').forEach(function (el) {
          const streamOk = stream === 'all' || el.dataset.streamEntry === stream;
          const agentOk = agent === 'all' || el.dataset.agentEntry === agent;
          el.style.display = streamOk && agentOk ? '' : 'none';
        });
        document.querySelectorAll('[data-stream-value]').forEach(function (btn) {
          btn.classList.toggle('active', btn.dataset.streamValue === stream);
        });
        document.querySelectorAll('[data-agent-value]').forEach(function (btn) {
          btn.classList.toggle('active', btn.dataset.agentValue === agent);
        });
        const url = new URL(location.href);
        if (stream === 'all') url.searchParams.delete('stream');
        else url.searchParams.set('stream', stream);
        if (agent === 'all') url.searchParams.delete('agent');
        else url.searchParams.set('agent', agent);
        history.pushState({}, '', url);
      }

      render();

      if (streamFilter) {
        streamFilter.addEventListener('click', function (e) {
          const btn = e.target.closest('[data-stream-value]');
          if (btn) {
            stream = btn.dataset.streamValue;
            render();
          }
        });
      }
      if (agentFilter) {
        agentFilter.addEventListener('click', function (e) {
          const btn = e.target.closest('[data-agent-value]');
          if (btn) {
            agent = btn.dataset.agentValue;
            render();
          }
        });
      }
    })();
  </script>
</BaseLayout>

<style>
  .archive-head {
    max-width: var(--entry-max);
    margin: var(--stack) 0 var(--section-gap-mobile);
  }

  .archive-head h1 {
    font-family: var(--font-display);
    font-size: var(--display-lg-size);
    font-weight: 500;
    margin: 0;
  }

  .lede {
    font-family: var(--font-body);
    font-size: var(--body-lg-size);
    line-height: var(--body-lg-lh);
    color: var(--ink-secondary);
    max-width: var(--reading-measure);
    margin: var(--stack) 0 0;
  }

  .entry-list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: var(--entry-max);
    display: flex;
    flex-direction: column;
    gap: var(--stack);
  }

  /* ── Polished FILTER / AGENT chip controls (contract tokens) ──────────────────
     Hidden until the inline script reveals it (the [hidden] attr handles the JS-off
     case; .js-only is a defensive belt for any path that forgets to set [hidden]). */
  .chip-filter[hidden] {
    display: none;
  }

  .chip-filter {
    display: flex;
    align-items: center;
    gap: var(--stack-tight);
    flex-wrap: wrap;
    max-width: var(--entry-max);
    margin: 0 0 var(--stack);
  }

  .chip-filter__label {
    font-family: var(--font-body);
    font-size: var(--type-eyebrow-size);
    font-weight: var(--label-caps-weight);
    letter-spacing: var(--type-eyebrow-ls);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-right: var(--stack-tight);
  }

  .filter-chip {
    font-family: var(--font-body);
    font-size: var(--body-sm-size);
    color: var(--ink-secondary);
    background: var(--surface-raised);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-full);
    padding: 4px 12px;
    cursor: pointer;
    transition:
      color 0.16s ease,
      border-color 0.16s ease,
      background 0.16s ease;
  }

  .filter-chip:hover {
    border-color: var(--border-strong);
    color: var(--ink-primary);
  }

  .filter-chip.active {
    color: var(--ink-on-accent);
    border-color: var(--brand);
    background: var(--brand);
  }

  @media (prefers-reduced-motion: reduce) {
    .filter-chip {
      transition: none;
    }
  }

  /* ── Archive row (elevated card) ─────────────────────────────────────────────
     .card-elevated supplies the surface/border/shadow + hover lift from the
     contract; the local rules add the stream-tinted left rail + inner layout. */
  .entry-row {
    display: block;
    position: relative;
    border-left: 3px solid var(--accent);
    padding: var(--stack);
    text-decoration: none;
  }

  .entry-row:hover {
    text-decoration: none;
  }

  .entry-row__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--gutter);
    margin-bottom: var(--stack-tight);
  }

  .entry-row__date {
    font-family: var(--font-body);
    font-size: var(--body-sm-size);
    color: var(--ink-muted);
  }

  .agent-chip {
    font-family: var(--font-mono);
    font-size: var(--body-sm-size);
    color: var(--ink-muted);
  }

  .entry-row__title {
    font-family: var(--font-display);
    font-size: var(--type-card-size);
    line-height: var(--type-card-lh);
    font-weight: 500;
    color: var(--ink-primary);
    margin: 0;
  }

  .entry-row__dek {
    font-family: var(--font-body);
    font-size: var(--body-size);
    line-height: 1.5;
    color: var(--ink-secondary);
    margin: var(--stack-tight) 0 0;
    /* one line: clamp to a single line at the row scale */
    display: -webkit-box;
    -webkit-line-clamp: 1;
    line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .entry-row__signals {
    display: flex;
    flex-wrap: wrap;
    gap: var(--stack-tight);
    margin-top: var(--stack);
  }

  .empty {
    color: var(--ink-muted);
  }
</style>
