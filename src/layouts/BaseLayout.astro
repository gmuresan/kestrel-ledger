---
// BaseLayout (Story 72.1, AC3) — site-wide shell. Loads the Aegentic tokens and the
// three webfonts (no runtime JS), renders a minimal nav, the page slot, and the
// footer verify block.
//
// Fonts via Bunny Fonts (privacy-friendly Google Fonts mirror, no cookies) using
// the preconnect + stylesheet pattern — no JS required (AC3).
import '../styles/tokens.css';
import FooterVerifyBlock from '../components/FooterVerifyBlock.astro';

interface Props {
  title: string;
  description?: string;
  wallet?: string;
  explorerUrl?: string;
  explorerName?: string;
}
const {
  title,
  description = 'Kestrel — the oversight agent that watches your onchain AI before it moves your money.',
  wallet,
  explorerUrl,
  explorerName,
} = Astro.props;

// Canonical URL for this page (Astro.site is set in astro.config.mjs). Used for og:url and
// to drive the active-route nav state below — no client JS needed.
const path = Astro.url.pathname;
const canonical = new URL(path, Astro.site ?? 'https://kestrelagent.xyz').href;
const ogImage = new URL('/og.png', Astro.site ?? 'https://kestrelagent.xyz').href;

// Active-route helper: a top-level path is active when the current path equals it or is nested
// under it (e.g. /ledger/2026-… → Ledger active). "/" matches only the home route exactly.
const isActive = (href: string): boolean =>
  href === '/' ? path === '/' : path === href || path.startsWith(`${href}/`);
const navLinks = [
  { href: '/ledger', label: 'Ledger' },
  { href: '/build-log', label: 'Build Log' },
  { href: '/about', label: 'About' },
  { href: '/waitlist', label: 'Waitlist' },
];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Brand: the K-monogram favicon + the dark-navy theme color (matches --surface-base). -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#0b0e14" />
    <link rel="canonical" href={canonical} />

    <!-- Social: Open Graph + Twitter card, driven by the page's title/description props.
         og:image / twitter:image point at /og.png (the binary is a separate follow-up). -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Kestrel Ledger" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- RSS discovery (feed.xml generated by astro build from src/pages/feed.xml.ts) -->
    <link rel="alternate" type="application/rss+xml" title="Kestrel Ledger" href="/feed.xml" />

    <!-- Fonts: Newsreader (serif/display), Inter (body/UI), JetBrains Mono (on-chain data) -->
    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.bunny.net/css?family=newsreader:400,500|inter:400,600|jetbrains-mono:500,600&display=swap"
    />
  </head>
  <body>
    <nav class="site-nav">
      <a class="wordmark" href="/" aria-label="Kestrel — home">
        {/* Brand glyph: K-monogram (matches favicon.svg). */}
        <svg
          class="brand-glyph"
          viewBox="0 0 32 32"
          width="22"
          height="22"
          aria-hidden="true"
          focusable="false"
        >
          <g fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11.5 7.5V24.5"/>
            <path d="M11.5 16L21 7.5"/>
            <path d="M11.5 16L21 24.5"/>
          </g>
        </svg>
        <span class="wordmark__text">Kestrel</span>
      </a>
      <div class="links">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class:list={['nav-link', { 'nav-link--active': isActive(link.href) }]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))
        }
        <a class="nav-link nav-link--ghost" href="/feed.xml">RSS</a>
      </div>
    </nav>

    <main class="site-main">
      <slot />
    </main>

    <FooterVerifyBlock wallet={wallet} explorerUrl={explorerUrl} explorerName={explorerName} />

    <style>
      /* Nav surface: a raised band sitting on the base canvas with a strong bottom
         divider so the masthead reads as chrome distinct from the page (contract:
         overlay/border tokens for sticky/chrome surfaces). */
      .site-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--gutter);
        max-width: var(--content-max);
        margin: 0 auto;
        padding: var(--stack) var(--margin-mobile);
        border-bottom: 1px solid var(--border-strong);
      }

      .wordmark {
        display: inline-flex;
        align-items: center;
        gap: var(--stack-tight);
        font-family: var(--font-display);
        font-size: var(--type-card-size);
        line-height: 1;
        font-weight: 500;
        color: var(--brand);
        text-decoration: none;
      }

      .wordmark:hover {
        text-decoration: none;
        color: var(--brand);
      }

      .brand-glyph {
        flex: 0 0 auto;
        display: block;
        color: var(--brand);
      }

      .wordmark__text {
        letter-spacing: -0.01em;
      }

      .links {
        display: flex;
        align-items: center;
        gap: var(--gutter);
      }

      .nav-link {
        position: relative;
        font-family: var(--font-body);
        font-size: var(--type-eyebrow-size);
        font-weight: var(--label-caps-weight);
        letter-spacing: var(--type-eyebrow-ls);
        text-transform: uppercase;
        color: var(--ink-secondary);
        text-decoration: none;
      }

      .nav-link:hover {
        color: var(--ink-primary);
        text-decoration: none;
      }

      /* Active route: amber ink + a hairline underline marker (the page you're on). */
      .nav-link--active {
        color: var(--brand);
      }

      .nav-link--active::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: -6px;
        height: 2px;
        border-radius: var(--radius-full);
        background: var(--brand);
      }

      /* RSS is secondary chrome — demoted to a quiet ghost weight (no caps emphasis,
         muted ink) so it doesn't compete with the primary nav. */
      .nav-link--ghost {
        font-weight: 400;
        letter-spacing: 0.04em;
        color: var(--ink-muted);
      }

      .nav-link--ghost:hover {
        color: var(--ink-secondary);
      }

      .site-main {
        max-width: var(--content-max);
        margin: 0 auto;
        padding: var(--stack) var(--margin-mobile) var(--section-gap-mobile);
      }

      /* ── Responsive shell (Story 72.3, AC5: breakpoints + mobile-nav) ── */
      /* Tablet: keep the nav on one row but let it wrap before clipping. */
      @media (max-width: 768px) {
        .site-nav {
          flex-wrap: wrap;
          gap: var(--stack);
        }
        .links {
          gap: var(--stack);
        }
      }

      /* Mobile: the nav links stack under the wordmark; tighter side padding so the
         reading column is full-width with breathing room. No JS — pure flex-wrap. */
      @media (max-width: 480px) {
        .site-nav {
          padding: var(--stack) 0.75rem;
        }
        .links {
          flex-basis: 100%;
          gap: 1rem;
        }
        .links a {
          font-size: var(--body-sm-size);
        }
        .site-main {
          padding: var(--stack) 0.75rem var(--section-gap-mobile);
        }
      }
    </style>
  </body>
</html>
